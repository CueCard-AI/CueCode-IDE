name: cuecode
title: CueCode
base: core24
version: "$RELEASE_VERSION"
summary: Spec-driven agent IDE
description: |
  CueCode is a fork of Zed, built for spec-driven agent workflows with local/BYOK
  models by default. Based on Zed (GPL-3.0-or-later).
grade: stable
confinement: classic
compression: lzo
website: https://github.com/cuecode/CueCode-Agents
source-code: https://github.com/cuecode/CueCode-Agents
issues: https://github.com/cuecode/CueCode-Agents/issues

parts:
  cuecode:
    plugin: dump
    source: "https://github.com/cuecode/CueCode-Agents/releases/download/v$RELEASE_VERSION/cuecode-linux-x86_64.tar.gz"

    organize:
      # These renames seem to not be necessary, but it's tidier.
      bin: usr/bin
      libexec: usr/libexec

    stage-packages:
      - libasound2t64
      # snapcraft has a lint that this is unused, but without it CueCode exits with
      # "Missing Vulkan entry points: LibraryLoadFailure" in wgpu.
      - libvulkan1
      # snapcraft has a lint that this is unused, but without it CueCode exits with
      # "NoWaylandLib" when run with Wayland.
      - libwayland-client0
      - libxcb1
      - libxkbcommon-x11-0
      - libxkbcommon0

    build-attributes:
      - enable-patchelf

    prime:
      # Omit unneeded files from the tarball
      - -lib
      - -licenses.md
      - -share

      # Omit unneeded files from stage-packages
      - -etc
      - -usr/share/doc
      - -usr/share/lintian
      - -usr/share/man

apps:
  cuecode:
    command: usr/bin/cuecode
    common-id: dev.cuecode.CueCode
    environment:
      CUECODE_BUNDLE_TYPE: snap
